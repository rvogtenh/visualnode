[Desktop Entry]
Type=Application
Name=Visual Node
Exec=bash -c 'for i in $(seq 1 30); do curl -s http://localhost:3000 > /dev/null 2>&1 && break; sleep 1; done; chromium-browser --kiosk --autoplay-policy=no-user-gesture-required --enable-web-midi --no-first-run --disable-infobars --disable-session-crashed-bubble --use-gl=egl --ignore-gpu-blocklist --enable-gpu-rasterization --enable-accelerated-2d-canvas --window-position=1920,0 --window-size=1024,600 --user-data-dir=/home/patch/.chromium-visualnode http://localhost:3000'
Hidden=false
X-GNOME-Autostart-enabled=true
